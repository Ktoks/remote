{
  "defaults": {
    "user": "ktoks",
    "port": "22",
    "security": {
      "allow_pipes": false,
      "allow_redirects": false,
      "allow_chaining": false
    },
    "allowed_commands": [
      "ls",
      "pwd",
      "whoami",
      "echo"
    ]
  },
  "hosts": {
    "localhost": {
      "ignore_host_key": true,
      "security": {
        "allow_pipes": true
      },
      "constraints": [
        {
          "command": "cat",
          "deny_args": ["/etc/shadow", "/etc/passwd", ".ssh"]
        },
        {
          "command": "ls",
          "allow_args": ["/home/ktoks", "/tmp", "-l"]
        }
      ]
    }
  }
}
